NAVER_ID=your_id_here
NAVER_PW=your_app_password_here
GOOGLE_DOC_ID=your_document_id_here

# [Required] Telegram Notification
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# [Optional] Local AI Server (Ollama) - Automatically discovered if not set
LOCAL_AI_IP=192.168.0.100


# [선택] Ollama 요약 모델 지정 - 미설정 시 기본값 llama3.2:1b (CPU 환경 추천)
# 사양에 따라 qwen2.5:3b 또는 qwen2.5:1.5b 등 사용 가능
OLLAMA_MODEL=llama3.2:1b
