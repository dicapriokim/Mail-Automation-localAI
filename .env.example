# ==========================================
# 1. MAIL ACCOUNT DETAILS (네이버 메일 연동 정보)
# ==========================================
NAVER_ID="your_naver_id_here"
NAVER_PW="your_app_password_here"

# ==========================================
# 2. GOOGLE DOCS INTEGRATION (구글 문서 연동 정보)
# ==========================================
GOOGLE_DOC_ID="your_google_document_id_here"

# ==========================================
# 3. AI PROVIDER & MODELS CONFIG (AI 엔진 및 모델 정보)
# ==========================================
AI_PROVIDER="OLLAMA"
LOCAL_AI_IP="192.168.0.100"
OLLAMA_MODEL="llama3.2:1b"
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-1.5-flash"
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4o-mini"

# ==========================================
# 4. NOTIFICATION GATEWAY SETTINGS (다중 알림 채널 정보)
# ==========================================
NOTIFY_CHANNEL="TELEGRAM"
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"
HA_URL="http://homeassistant.local:8123"
HA_TOKEN="your_ha_long_lived_token_here"
HA_MOBILE_ENTITY="mobile_app_your_device_entity_id"
